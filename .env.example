# Optional overrides for the local Docker stack. Copy to `.env` (gitignored) to use;
# every value has a sane default baked into docker/docker-compose.yml, so the stack
# runs with no .env at all. run.sh passes this file to Compose via --env-file.

# --- Host ports (change if something already binds these) ---
WEB_PORT=3000
API_PORT=8080
POSTGRES_PORT=5432
PROXY_PORT=1080

# --- Postgres (must stay in sync with the API's `local` profile) ---
POSTGRES_DB=vechemoga
POSTGRES_USER=vechemoga
POSTGRES_PASSWORD=vechemoga

# --- Provider proxy-mock (the `provider-proxy` service; see provider-proxy/README.md) ---
# Where the proxy forwards traffic that NO expectation matched. Left unset on purpose:
# unmatched mail then 502s loudly instead of reaching a real inbox. An unmatched send is
# either a test that forgot to register an expectation, or you hand-registering in the
# browser - neither should be able to email a real person.
#
# Uncomment to forward unmatched traffic to the real provider instead. Real delivery also
# needs the API to run with a non-empty LOOPS_API_KEY (it is empty in the `local` profile,
# so a forwarded send 401s today - do not rely on that as the safety net).
# PROXY_UPSTREAM_URL=https://app.loops.so/api
