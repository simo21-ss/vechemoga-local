# Optional overrides for the local Docker stack. Copy to `.env` (gitignored) to use;
# every value has a sane default baked into docker/docker-compose.yml, so the stack
# runs with no .env at all. run.sh passes this file to Compose via --env-file.

# --- Host ports (change if something already binds these) ---
WEB_PORT=3000
API_PORT=8080
POSTGRES_PORT=5432
PROXY_PORT=1080

# --- Postgres (must stay in sync with the API's `local` profile) ---
POSTGRES_DB=vechemoga
POSTGRES_USER=vechemoga
POSTGRES_PASSWORD=vechemoga

# --- Provider mock (the `provider-proxy` service) ---
# The compose default is already a pinned SHA; set TAG only to move or roll back. Never
# `latest` — that tag still resolves to the retired Node proxy (run.sh refuses it). IMAGE
# points at a locally built image; from THIS directory (the repo root, where .env lives):
#   docker build -t vechemoga/provider-proxy:dev ../VecheMogaProviderProxy
# PROVIDER_PROXY_IMAGE=776051122865.dkr.ecr.eu-central-1.amazonaws.com/vechemoga/provider-proxy
# PROVIDER_PROXY_TAG=b52518d089bf

# There is no upstream/passthrough knob — the mock takes no environment and fails closed.
