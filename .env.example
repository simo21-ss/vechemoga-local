# Optional overrides for the local Docker stack. Copy to `.env` (gitignored) to use;
# every value has a sane default baked into docker/docker-compose.yml, so the stack
# runs with no .env at all. run.sh passes this file to Compose via --env-file.

# --- Host ports (change if something already binds these) ---
WEB_PORT=3000
API_PORT=8080
POSTGRES_PORT=5432
PROXY_PORT=1080

# --- Postgres (must stay in sync with the API's `local` profile) ---
POSTGRES_DB=vechemoga
POSTGRES_USER=vechemoga
POSTGRES_PASSWORD=vechemoga

# --- Provider proxy-mock (the `provider-proxy` service; see provider-proxy/README.md) ---
# Where the proxy forwards traffic that NO expectation matched. Left unset on purpose, and
# that is the entire safety property of the local stack: the API's `local` profile points
# both of its Loops base-urls at the proxy, so with no upstream configured there is no code
# path from your machine to a real inbox. Unmatched traffic is stubbed 200 and recorded in
# the journal instead, which is why the ESP poller can sweep away in the background without
# anyone registering an expectation for it.
#
# Uncomment to forward unmatched traffic to the real provider instead. The `local` profile's
# dummy LOOPS_API_KEY is not a safety net - it only means a forwarded send 401s rather than
# delivering.
# PROXY_UPSTREAM_URL=https://app.loops.so/api
